{
  "name": "use-step-wizard",
  "version": "1.0.1",
  "description": "A small React wizard state and component library.",
  "license": "MIT",
  "author": "Pabs Romero Jr.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc --emitDeclarationOnly && node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "wizard",
    "steps",
    "hook",
    "multi-step",
    "form"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "esbuild": "^0.25.6",
    "react": "^18.3.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ppromerojr/use-step-wizard.git"
  }
}
